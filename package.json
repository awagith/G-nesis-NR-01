{
  "name": "genesis-nr01",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "build": "tsc -b && vite build --mode production",
    "build:staging": "tsc -b && vite build --mode staging",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "supabase:setup:dev": "powershell -ExecutionPolicy Bypass -File scripts/setup-dev.ps1",
    "supabase:setup:staging": "powershell -ExecutionPolicy Bypass -File scripts/setup-staging.ps1",
    "supabase:setup:prod": "powershell -ExecutionPolicy Bypass -File scripts/setup-prod.ps1",
    "supabase:gen-types": "powershell -ExecutionPolicy Bypass -File scripts/gen-types.ps1",
    "supabase:gen-types:staging": "powershell -ExecutionPolicy Bypass -File scripts/gen-types.ps1 -Env staging"
  },
  "dependencies": {
    "@supabase/auth-helpers-react": "^0.15.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.95.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
